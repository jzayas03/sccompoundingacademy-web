# ─────────────────────────────────────────────────────────────────────────────
# Resend — transactional email (contact form, inscription confirmation,
# internal notifications). Sign up at https://resend.com → API Keys.
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Email address that receives contact-form submissions
CONTACT_INBOX_EMAIL=scpcpr@gmail.com
# From-address used for outbound mail. Once the Resend sender domain is
# verified on sccompoundingacademy.com, set this to
# 'Santa Cruz Compounding Academy <inscripciones@sccompoundingacademy.com>'.
CONTACT_FROM_EMAIL=
RESEND_FROM=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — payment processing for course enrollment.
# Create at https://stripe.com → API keys. Use TEST keys (sk_test_…) during
# development; flip to LIVE keys (sk_live_…) only after end-to-end testing.
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From Stripe Dashboard → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs — one per course. Create the 3 Products in Stripe
# Dashboard with a one-time Price each, then paste the price_… IDs here.
STRIPE_PRICE_USP_795=
STRIPE_PRICE_USP_800=
STRIPE_PRICE_COMBINADO=

# ─────────────────────────────────────────────────────────────────────────────
# Airtable — enrollment registry (graceful degradation: enrollment + emails
# still work if these are missing, but no row gets persisted).
# Personal Access Token at https://airtable.com/create/tokens with scopes
# data.records:read + data.records:write on the SCCA base.
# ─────────────────────────────────────────────────────────────────────────────
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Canonical site URL (used for Stripe success/cancel redirects). When set,
# overrides the request origin — useful in dev to point at the deployed
# preview, or to lock down a custom domain in production.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
