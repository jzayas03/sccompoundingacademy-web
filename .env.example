# =============================================================================
# Santa Cruz Compounding Academy — environment variables
# Copy this file to `.env.local` (git-ignored) and fill in real values for
# local development. In production, set these in Vercel → Settings → Env Vars.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Canonical site URL — used for Stripe Checkout redirects, OG/Twitter share
# tags, JSON-LD `@id` resolution, and Auth.js `AUTH_URL`. Must be the custom
# domain in production. The runtime helper (src/lib/siteUrl.ts) rejects
# `.vercel.app` hostnames so a misconfigured value falls back to the
# canonical domain in prod.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sccompoundingacademy.com

# ─────────────────────────────────────────────────────────────────────────────
# Resend — transactional email (contact form, inscription confirmation,
# internal notifications, portal magic-link sign-ins). Sign up at
# https://resend.com → API Keys; verify the sender domain before going live.
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Outbound sender for all transactional emails (Stripe webhook + Auth.js
# magic links). Must be a verified Resend sender.
EMAIL_FROM="Santa Cruz Compounding Academy <noreply@sccompoundingacademy.com>"
# Reply-to address on outbound emails AND the inbox that receives contact-form
# submissions + internal enrollment notifications. Routed via Cloudflare Email
# Routing catch-all → backend Gmail inbox.
EMAIL_REPLY_TO=info@sccompoundingacademy.com
# Legacy aliases — honored as fallbacks during the migration to EMAIL_*.
# Safe to leave blank once EMAIL_FROM / EMAIL_REPLY_TO are set.
RESEND_FROM=
CONTACT_FROM_EMAIL=
CONTACT_INBOX_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Vercel Blob — stores the student matrícula photo uploaded for the student-tier
# verification gate (/portal/verificacion). Create a Blob store in the Vercel
# project; the token is auto-injected in Vercel deploys. Set it locally to test
# uploads. The photo is deleted as soon as the owner approves/rejects.
# ─────────────────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — payment processing for course enrollment. Create at
# https://stripe.com → API keys. Use TEST keys (sk_test_…) during development;
# flip to LIVE keys (sk_live_…) only after end-to-end testing.
# Two Prices under one Product: profesional ($2,350) and student ($495).
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From Stripe Dashboard → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs — both prices belong to the same Product
# ("Basic Compounding No Estéril"). Profesional covers RPh pharmacists +
# licensed pharmacy technicians ($2,350); Student is gated to non-licensed
# pharmacy students ($495).
STRIPE_PRICE_ID_PROFESIONAL=
STRIPE_PRICE_ID_STUDENT=

# ─────────────────────────────────────────────────────────────────────────────
# Airtable — enrollment registry (graceful degradation: enrollment + emails
# still work if these are missing, but no row gets persisted).
# Personal Access Token at https://airtable.com/create/tokens with scopes
# data.records:read + data.records:write on the SCCA base.
# ─────────────────────────────────────────────────────────────────────────────
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Student portal (Phase A) — only required for /portal/* routes. Provision
# via Vercel Marketplace → Storage → Neon Postgres; the integration injects
# DATABASE_URL automatically. AUTH_SECRET should be a high-entropy string
# generated with `openssl rand -base64 32`.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=
AUTH_SECRET=
# Public origin Auth.js uses to build callback URLs. Typically the same as
# NEXT_PUBLIC_SITE_URL.
AUTH_URL=https://sccompoundingacademy.com
# Passing threshold for module post-tests (0.70 = 70%). Tunable without
# code changes; bump to 0.80 if SCCA wants stricter completion criteria.
QUIZ_PASSING_THRESHOLD=0.70
# First certificate sequence number for the current calendar year (so the
# first cert becomes SCCA-2026-001). Bump manually each Jan.
CERTIFICATE_YEAR_SEQUENCE_START=1

# ──────────────────────────────────────────────────────────────────────
# ACPE Standard 3 disclosure block (rendered on the portal dashboard).
# Defaults in src/components/portal/AcpeDisclosure.tsx — set these to
# override when a cohort's faculty or planning team has a relationship
# to disclose. Plain text, no Markdown.
# ──────────────────────────────────────────────────────────────────────
ACPE_DISCLOSURE_HEADING_ES=
ACPE_DISCLOSURE_BODY_ES=

# ──────────────────────────────────────────────────────────────────────
# Cron auth — shared secret between the send-review-invites GitHub
# Actions workflow and the /api/cron/review-invites route. Set the same
# value in GitHub repo secrets and in Vercel Production env vars.
# Generate with: `openssl rand -hex 32`.
# ──────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Upstash Redis — distributed rate limiting for /api/inscripcion and
# /api/contact (abuse / bot-spam / card-testing shield). Provision via
# Vercel → Marketplace → Upstash (Redis); the integration auto-injects
# both vars. LEAVE BLANK to disable rate limiting (requests pass through —
# safe, just unprotected).
# ──────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Cloudflare Turnstile — free CAPTCHA on the enrollment form. Create a
# widget at https://dash.cloudflare.com → Turnstile (domain = the apex
# sccompoundingacademy.com). The Site Key is public (inlined in the
# browser bundle); the Secret Key is server-only. LEAVE BLANK to disable
# the CAPTCHA gate (the widget won't render and the server skips
# verification).
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────
# Ops alerts — inbox that receives operational failure alerts from the
# Stripe webhook (e.g. "paid but DB upsert failed"). Defaults to
# EMAIL_REPLY_TO (info@…) when unset. Sent via Resend, so RESEND_API_KEY
# must be configured for alerts to actually deliver.
# ──────────────────────────────────────────────────────────────────────
ALERT_EMAIL=
